#!/usr/bin/env bash

PULL='.pull'
SUB='.submodules'

case $1 in
    clean)
        echo pull and update submodules
        rm $PULL $SUB
        ;;
    *)
        ;;
esac


find $DUMP_DIR -name $PULL -mtime +1 -delete
if [ ! -f $PULL ]; then
    echo pull latest changes
    git pull
    touch $PULL
fi

find $DUMP_DIR -name $SUB -mtime +7 -delete

PUPPET_MODULES=''

if [[ $OSTYPE == 'darwin'* ]]; then
    PUPPET_INSTALL='puppet module install'
    PUPPET_APPLY='puppet apply -v'
    PUPPET_MODULES=":$HOME/.puppetlabs/etc/code/modules/"
else
    PUPPET_MODULES=":/etc/puppetlabs/code/modules/"
    if [ -e /bin/sudo ]; then
        PUPPET_INSTALL='sudo puppet module install'
        PUPPET_APPLY='sudo puppet apply -v'
    fi
fi



if [ ! -f $SUB ]; then
    echo update submodules
    ${PUPPET_INSTALL} puppetlabs-stdlib
    ${PUPPET_INSTALL} puppetlabs-vcsrepo

    if [[ $OSTYPE == 'darwin'* ]]; then
        ${PUPPET_INSTALL} thekevjames-homebrew --version 1.9.1
    fi

    touch $SUB
fi

if [[ -f ~/.keys/env ]]; then
    source ~/.keys/common_env
fi

sshj_fact="${FACTER_SSHJ_FACT:-}"
if [[ -z $sshj_fact && -n $FACTER_SSHJ_SPEC ]]; then
    sshj_fact="$FACTER_SSHJ_SPEC"
fi

if [[ -n $sshj_fact ]]; then
    if [[ $OSTYPE == 'darwin'* ]]; then
        export FACTER_SSHJ_FACT="$sshj_fact"
        export PUPPET_APPLY="puppet apply -v"
    else
        export PUPPET_APPLY="sudo FACTER_SSHJ_FACT=${sshj_fact} puppet apply -v"
    fi
fi

set -x
${PUPPET_APPLY} \
    --modulepath `pwd`/modules${PUPPET_MODULES} \
    manifests/hosts.pp $@
{ set +x; } 2>/dev/null

if [[ $OSTYPE != darwin* ]] && command -v niri_outputs.py >/dev/null 2>&1; then
    niri_pid=$(pgrep -x niri | head -1)
    if [[ -n $niri_pid ]]; then
        runtime_dir="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
        niri_socket=$(ls -1t "$runtime_dir"/niri.wayland-*."$niri_pid".sock 2>/dev/null | head -1)
        if [[ -n $niri_socket ]]; then
            NIRI_SOCKET="$niri_socket" niri_outputs.py || true
        fi
    fi
fi
